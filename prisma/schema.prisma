generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  products     Product[]
  walletConfig WalletConfig?
  marketing    MarketingAsset[]
  auditLogs    AuditLog[]
}

model Product {
  id           String           @id @default(cuid())
  userId       String
  slug         String           @unique
  niche        String
  type         String
  title        String
  subtitle     String
  description  String
  priceCents   Int
  currency     String           @default("USD")
  status       ProductStatus    @default(DRAFT)
  content      Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions     ProductVersion[]
  landingPage  LandingPage?
  orders       Order[]
  marketing    MarketingAsset[]

  @@index([userId])
  @@index([status])
}

model ProductVersion {
  id           String   @id @default(cuid())
  productId    String
  version      Int
  title        String
  editableJson Json
  pdfUrl       String?
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, version])
}

model LandingPage {
  id             String    @id @default(cuid())
  productId      String    @unique
  slug           String    @unique
  headline       String
  problem        String
  valueProp      String
  benefits       Json
  includes       Json
  faq            Json
  guarantee      String
  visits         Int       @default(0)
  purchases      Int       @default(0)
  conversionRate Float     @default(0)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  country   String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              String         @id @default(cuid())
  productId       String
  customerId      String?
  status          OrderStatus    @default(PENDING)
  totalCents      Int
  currency        String         @default("USD")
  stripeSessionId String?        @unique
  bitcoinInvoice  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  product         Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  customer        Customer?      @relation(fields: [customerId], references: [id])
  payments        Payment[]
  downloadLinks   DownloadLink[]

  @@index([productId])
  @@index([customerId])
  @@index([status])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  provider    String
  amountCents Int
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  externalId  String?
  receivedAt  DateTime?
  createdAt   DateTime      @default(now())
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model DownloadLink {
  id            String    @id @default(cuid())
  orderId       String
  token         String    @unique
  expiresAt     DateTime
  usedAt        DateTime?
  maxDownloads  Int       @default(3)
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([expiresAt])
}

model WalletConfig {
  id                String   @id @default(cuid())
  userId            String   @unique
  publicAddress     String
  label             String?
  preferredCurrency String   @default("USD")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketingAsset {
  id           String   @id @default(cuid())
  userId       String
  productId    String?
  channel      String
  kind         String
  copy         String
  variant      String
  calendarDate DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([productId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
